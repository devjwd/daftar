{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@daftar/shared-types": [
        "../../packages/shared-types/src/index"
      ]
    }
  },
  "include": [
    "src/**/*",
    "index.ts",
    "worker.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}