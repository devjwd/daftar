{
  "name": "movement-badge-service",
  "version": "1.0.0",
  "description": "Repository utilities for the Movement badge app",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.js",
    "start": "npm run start --workspace=apps/server",
    "dev": "concurrently -n \"server,frontend\" -c \"magenta,cyan\" \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "test": "node scripts/testBadgeSystem.js",
    "test:badges": "node scripts/testBadgeSystem.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}