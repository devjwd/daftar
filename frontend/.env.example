# Movement Network Portfolio Manager - Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ===== NETWORK CONFIGURATION =====
# Set to 'testnet' or 'mainnet'
# Mainnet: https://mainnet.movementnetwork.xyz/v1
# Testnet: https://testnet.movementnetwork.xyz/v1
VITE_NETWORK=mainnet

# ===== SMART CONTRACT ADDRESSES =====
# Deploy your swap router contract and add address here
# Mainnet deployment: 2026-03-16 | Tx: 0x102078f8c03ebaeee2b111d3269acdcdcb6501d166e2cbf5034bea6c5f9084f2
VITE_SWAP_ROUTER_ADDRESS=0x61ed30854e689da3c31d2e07b55fd94add415aac102d2dd7f831bf5c294757e3

# Badge system module address (usually same as swap router)
VITE_BADGE_MODULE_ADDRESS=0x61ed30854e689da3c31d2e07b55fd94add415aac102d2dd7f831bf5c294757e3
VITE_BADGE_SBT_MODULE_ADDRESS=0x61ed30854e689da3c31d2e07b55fd94add415aac102d2dd7f831bf5c294757e3

# ===== BADGE BACKEND ATTESTATION (server-side only, do NOT expose in client) =====
# Used by /api/badges/award and /api/badges/scan to write allowlist attestations on-chain.
# Set these in your serverless environment (Vercel Project Settings), not in browser env files.
BADGE_MODULE_ADDRESS=0x61ed30854e689da3c31d2e07b55fd94add415aac102d2dd7f831bf5c294757e3
BADGE_ATTESTOR_PRIVATE_KEY=
BADGE_ATTESTOR_ADDRESS=
MOVEMENT_RPC_URL=https://mainnet.movementnetwork.xyz/v1

# Admin wallet address - only this address can access /admin
# Defaults to VITE_SWAP_ROUTER_ADDRESS if not set
VITE_ADMIN_ADDRESS=0x61ed30854e689da3c31d2e07b55fd94add415aac102d2dd7f831bf5c294757e3

# ===== API CONFIGURATION =====
# Mosaic DEX Aggregator API Base URL (frontend fallback/default)
VITE_MOSAIC_API_URL=https://api.mosaic.ag/v1

# ===== SERVER-SIDE SWAP PROXY (set in Vercel Project Environment Variables) =====
# Do NOT prefix with VITE_. This key stays on backend routes only.
MOSAIC_API_URL=https://api.mosaic.ag/v1
MOSAIC_API_KEY=

# CoinGecko API for token pricing
# Free tier: no authentication required
# For higher rate limits, get API key: https://www.coingecko.com/en/api/documentation
VITE_COINGECKO_API_KEY=

# ===== ERROR TRACKING =====
# Sentry.io for error tracking and monitoring
# Sign up at: https://sentry.io
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== ANALYTICS =====
# Google Analytics
# Get tracking ID from: https://analytics.google.com
VITE_GOOGLE_ANALYTICS_ID=

# Mixpanel Analytics
# Get token from: https://mixpanel.com
VITE_MIXPANEL_TOKEN=

# ===== FEATURE FLAGS =====
# Enable/disable features in production
VITE_ENABLE_SWAP=true
VITE_ENABLE_BADGES=true
VITE_ENABLE_PORTFOLIO_EXPORT=true
VITE_ENABLE_PORTFOLIO_ALERTS=false

# ===== PERFORMANCE =====
# Enable debug logging in production (be careful, impacts performance)
VITE_DEBUG_MODE=false

# API timeout in milliseconds
VITE_API_TIMEOUT=10000

# Price update interval in milliseconds (minimum recommended: 30000)
VITE_PRICE_UPDATE_INTERVAL=60000

# ===== DEVELOPMENT =====
# These are typically set by the build tool, but can be overridden here
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5173
