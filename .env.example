# Vite (Frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key_here
VITE_NETWORK=mainnet
VITE_SWAP_ROUTER_ADDRESS=0x...
